# LiveKit (required)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_URI=
LIVEKIT_WORKER_HOST=
LIVEKIT_WORKER_PORT=8081

# Deepgram (required)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# OpenAI (required)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ElevenLabs (required)
ELEVENLABS_API_KEY=
# Optional alias used by some SDK paths
ELEVEN_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_flash_v2_5

# Airtable (required)
AIRTABLE_PAT=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE=call_logs

# Twilio (required for webhook validation)
TWILIO_CALL_ROUTING_MODE=webhook
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_HOST=0.0.0.0
TWILIO_WEBHOOK_PORT=8080
TWILIO_WEBHOOK_PUBLIC_URL=
TWILIO_SIP_AUTH_USERNAME=
TWILIO_SIP_AUTH_PASSWORD=

# Voice behavior / safety tuning
GREETING_TEXT=Hello, thanks for calling. How can I help you today?
MAX_CALL_DURATION_SECONDS=900

# VAD tuning (Silero)
VAD_THRESHOLD=0.55
VAD_MIN_SPEECH_DURATION=0.18
VAD_MIN_SILENCE_DURATION=0.6
VAD_SPEECH_PAD=0.12

# Interruption / endpointing tuning
INTERRUPT_SPEECH_DURATION=0.2
MIN_ENDPOINTING_DELAY=0.3
MAX_ENDPOINTING_DELAY=2.2

# Optional logging
LOG_LEVEL=INFO
UVICORN_LOG_LEVEL=info
