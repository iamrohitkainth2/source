# LiveKit (required)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_URI=
LIVEKIT_WORKER_HOST=
LIVEKIT_WORKER_PORT=8081

# Deepgram (required)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# LLM provider
OPENAI_PROVIDER=openai

# OpenAI (required when OPENAI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.4

# Azure OpenAI (required when OPENAI_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_AD_TOKEN=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_MODEL=
AZURE_OPENAI_API_VERSION=

# ElevenLabs (required)
ELEVENLABS_API_KEY=
# Optional alias used by some SDK paths
ELEVEN_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5
# Optional stability knobs for streaming calls
ELEVENLABS_AUTO_MODE=false
ELEVENLABS_TEXT_NORMALIZATION=on
# Optional comma-separated fallback models used when startup probe returns no audio frames
ELEVENLABS_FALLBACK_MODELS=eleven_turbo_v2_5,eleven_multilingual_v2
TTS_PROBE_TEXT=Hello, this is a voice test.

# TTS provider routing
TTS_PROVIDER=openai
TTS_ENABLE_PROVIDER_FALLBACK=true
# Used when falling back to OpenAI/Azure TTS
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=ash
# Optional dedicated Azure deployment for TTS (falls back to AZURE_OPENAI_DEPLOYMENT)
AZURE_OPENAI_TTS_DEPLOYMENT=
# Optional dedicated Azure endpoint/API version for TTS (fallbacks to AZURE_OPENAI_* defaults)
AZURE_OPENAI_TTS_ENDPOINT=
AZURE_OPENAI_TTS_API_VERSION=
# Optional dedicated Azure API key for TTS (falls back to AZURE_OPENAI_API_KEY)
AZURE_OPENAI_TTS_API_KEY=

# Airtable (required)
AIRTABLE_PAT=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE=call_logs
# Optional but recommended: stable table reference (starts with tbl...)
AIRTABLE_TABLE_ID=
# Optional field-name mapping (set these if your Airtable column names differ)
AIRTABLE_FIELD_CALLER_NUMBER=caller_number
AIRTABLE_FIELD_DURATION_SECONDS=duration_seconds
AIRTABLE_FIELD_TRANSCRIPT=transcript
AIRTABLE_FIELD_CREATED_AT=created_at

# Twilio (required for webhook validation)
TWILIO_CALL_ROUTING_MODE=webhook
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_HOST=0.0.0.0
TWILIO_WEBHOOK_PORT=8080
TWILIO_WEBHOOK_PUBLIC_URL=
TWILIO_SIP_AUTH_USERNAME=
TWILIO_SIP_AUTH_PASSWORD=

# Voice behavior / safety tuning
GREETING_TEXT=Hello, thanks for calling. How can I help you today?
MAX_CALL_DURATION_SECONDS=900

# VAD tuning (Silero)
VAD_THRESHOLD=0.55
VAD_MIN_SPEECH_DURATION=0.18
VAD_MIN_SILENCE_DURATION=0.6
VAD_SPEECH_PAD=0.12

# Interruption / endpointing tuning
INTERRUPT_SPEECH_DURATION=0.2
MIN_ENDPOINTING_DELAY=0.3
MAX_ENDPOINTING_DELAY=2.2

# Optional logging
LOG_LEVEL=INFO
UVICORN_LOG_LEVEL=info
